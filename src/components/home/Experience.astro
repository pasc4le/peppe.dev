---
import { getCollection } from "astro:content";
import ExperienceRenderer from "./ExperienceRenderer.astro";

const experience = (await getCollection("experience")).toSorted(
  (a, b) => +b.data.startDate - +a.data.startDate,
);
---

<div class="mt-3">
  {experience.map((entry) => <ExperienceRenderer {entry} />)}
</div>
